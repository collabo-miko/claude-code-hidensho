{
  "permissions": {
    "allow": [
      "Read",
      "Bash(npm run *)",
      "Bash(npx jest *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)"
    ],
    "deny": [
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.next/**)",
      "Read(coverage/**)",
      "Read(*.lock)",
      "Read(*.min.js)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "MAX_THINKING_TOKENS": "8000",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./filter-test-output.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ./truncate-output.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ./filter-build-output.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- [PostCompact] コンパクション完了。/context でコンテキスト使用量を確認してください ---' >&2; exit 0"
          }
        ]
      }
    ]
  }
}
