{
  "permissions": {
    "allow": [
      "Read",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(node *)",
      "Bash(npm test *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(env)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Edit(.env*)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.example) exit 0;; esac; echo \"$FILE\" | grep -qE '(\\.env($|\\..+)|\\.pem$|\\.key$)' && { echo \"セキュリティフック: 機密ファイル $FILE への書き込みをブロックしました\" >&2; exit 2; } || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty'); echo \"$CMD\" | grep -qE '(\\brm\\s+.*-[a-zA-Z]*r|\\btruncate\\b|\\bdd\\b|\\bmkfs\\b|\\bsudo\\b|\\bchmod\\s+777)' && { echo \"セキュリティフック: 危険なコマンドをブロックしました: $CMD\" >&2; exit 2; } || exit 0"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.aws", "/etc/passwd"],
      "denyWrite": ["~/.ssh", "~/.aws"]
    }
  }
}
